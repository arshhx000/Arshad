<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Disystem</title>
    
    <!-- React & ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    
    <!-- Babel for JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Mr+Dafoe&display=swap" rel="stylesheet">
    
    <style>
        body { 
            font-family: 'Mr Dafoe', cursive;
            font-weight: 400;
            background-color: #e5e5e5; 
            background-image: radial-gradient(#d1d1d1 1px, transparent 0);
            background-size: 20px 20px;
        }

        /* Base prominent shadow for panels */
        .te-shadow { 
            box-shadow: 4px 4px 0px 0px rgba(0,0,0,1); 
            transition: all 0.1s ease;
        }
        /* Small shadow for buttons/inputs */
        .te-shadow-sm { 
            box-shadow: 2px 2px 0px 0px rgba(0,0,0,1); 
            transition: all 0.1s ease;
        }
        
        /* Active states simulating physical pressing down */
        .te-active:active { 
            box-shadow: 0px 0px 0px 0px rgba(0,0,0,1) !important; 
            transform: translate(2px, 2px) !important; 
        }

        /* Inner shadow for "sunken" areas */
        .te-inset-shadow {
            box-shadow: inset 2px 2px 0px 0px rgba(0,0,0,0.1);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #e5e5e5; border-left: 1px solid #000; border-top: 1px solid #000; }
        ::-webkit-scrollbar-thumb { background: #000; border: 1px solid #e5e5e5; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState } = React;

        function App() {
            const [plans, setPlans] = useState([]);

            // Helper to format title case for "This Ok" casing
            const toTitleCase = (str) => {
                return str.replace(/_/g, ' ').toLowerCase().split(' ').map(word => 
                    word.charAt(0).toUpperCase() + word.slice(1)
                ).join(' ');
            };

            const handleFileUpload = (event) => {
                const file = event.target.files[0];
                if (!file) return;

                const reader = new FileReader();
                reader.onload = (e) => {
                    try {
                        const json = JSON.parse(e.target.result);
                        let newPlans = Array.isArray(json) ? json : [json];
                        newPlans = newPlans.map(plan => ({
                            id: crypto.randomUUID(),
                            title: toTitleCase(plan.title || 'Untitled Plan'),
                            days: (plan.days || []).map(d => ({
                                ...d,
                                tasks: d.tasks.map(t => ({ ...t, title: toTitleCase(t.title) }))
                            })),
                            currentDayIndex: 0
                        }));
                        setPlans(prev => [...prev, ...newPlans]);
                    } catch (err) {
                        console.error(err);
                    }
                };
                reader.readAsText(file);
                event.target.value = '';
            };

            const downloadSampleJSON = () => {
                const sample = { title: "7_Day_Pushup_Protocol", days: [{ day: 1, tasks: [{ id: 1, title: "Warmup_Stretch", completed: false }] }] };
                const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(sample, null, 2));
                const a = document.createElement('a'); a.href = dataStr; a.download = "plan.json"; a.click();
            };

            const toggleTask = (planId, dayIndex, taskId) => {
                setPlans(plans.map(p => p.id === planId ? { ...p, days: p.days.map((d, i) => i === dayIndex ? { ...d, tasks: d.tasks.map(t => t.id === taskId ? {...t, completed: !t.completed} : t) } : d) } : p));
            };

            const setDay = (planId, dayIndex) => {
                setPlans(plans.map(p => p.id === planId ? { ...p, currentDayIndex: dayIndex } : p));
            };

            const deletePlan = (planId) => {
                setPlans(plans.filter(p => p.id !== planId));
            };

            const getProgress = (day) => {
                if (!day || !day.tasks || day.tasks.length === 0) return 0;
                return Math.round((day.tasks.filter(t => t.completed).length / day.tasks.length) * 100);
            };

            return (
                <div className="min-h-screen p-4 md:p-8">
                    <div className="max-w-xl mx-auto space-y-6">
                        
                        {/* Compact Control Deck */}
                        <div className="border-2 border-black bg-white p-3 te-shadow flex items-center justify-between">
                            <div className="bg-black text-white p-2 border-2 border-black">
                                <svg className="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><rect x="3" y="3" width="18" height="18"/><path d="M7 8l4 4-4 4M13 16h4"/></svg>
                            </div>
                            <div className="flex gap-2">
                                <button onClick={downloadSampleJSON} className="border-2 border-black bg-[#00E5FF] p-2 te-shadow-sm te-active">
                                    <svg className="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M21 15v4H3v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                </button>
                                <label className="border-2 border-black bg-[#FF6B00] p-2 te-shadow-sm te-active cursor-pointer">
                                    <svg className="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M21 15v4H3v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                    <input type="file" accept=".json" onChange={handleFileUpload} className="hidden" />
                                </label>
                            </div>
                        </div>

                        {plans.length === 0 ? (
                            <div className="border-2 border-black bg-white p-8 text-center te-shadow">
                                <h2 className="text-xl">Awaiting Input</h2>
                            </div>
                        ) : (
                            plans.map(plan => (
                                <div key={plan.id} className="border-2 border-black bg-white te-shadow">
                                    {/* Compact Header */}
                                    <div className="border-b-2 border-black p-4 bg-[#FFD600] flex justify-between items-center">
                                        <h2 className="text-xl truncate">{plan.title}</h2>
                                        <div className="flex items-center gap-3">
                                            <div className="text-sm border-2 border-black bg-black text-[#FFD600] px-2 py-0.5">{Math.round(plan.days.reduce((acc, d) => acc + getProgress(d), 0) / plan.days.length || 0)}%</div>
                                            <button onClick={() => deletePlan(plan.id)} className="border-2 border-black bg-red-500 text-white px-2 py-0.5 text-xs te-shadow-sm te-active">Del</button>
                                        </div>
                                    </div>

                                    {/* Day Navigation */}
                                    <div className="flex border-b-2 border-black bg-[#d4d4d4] p-1 gap-1 overflow-x-auto">
                                        {plan.days.map((day, idx) => (
                                            <button key={idx} onClick={() => setDay(plan.id, idx)} className={`px-3 py-1 text-sm border-2 border-black ${plan.currentDayIndex === idx ? 'bg-[#FF6B00] te-shadow-sm' : 'bg-white'}`}>
                                                Day {day.day}
                                            </button>
                                        ))}
                                    </div>

                                    <div className="p-4 bg-white">
                                        {plan.days[plan.currentDayIndex] && (
                                            <div>
                                                <div className="flex justify-between items-center mb-4 border-b border-black pb-2">
                                                    <h3 className="text-lg">Day {plan.days[plan.currentDayIndex].day}</h3>
                                                    <span className="text-sm bg-gray-200 px-2 py-0.5 border border-black">{getProgress(plan.days[plan.currentDayIndex])}%</span>
                                                </div>
                                                <div className="space-y-3">
                                                    {plan.days[plan.currentDayIndex].tasks.map(task => (
                                                        <div key={task.id} onClick={() => toggleTask(plan.id, plan.currentDayIndex, task.id)} className={`border-2 border-black p-2 flex items-center gap-3 cursor-pointer ${task.completed ? 'bg-gray-100' : 'bg-white'}`}>
                                                            <div className={`w-6 h-6 border-2 border-black ${task.completed ? 'bg-[#00E5FF]' : ''}`}></div>
                                                            <span className={`text-base ${task.completed ? 'line-through text-gray-500' : ''}`}>{task.title}</span>
                                                        </div>
                                                    ))}
                                                </div>
                                            </div>
                                        )}
                                    </div>
                                </div>
                            ))
                        )}
                    </div>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
