4) 1² up to n² summations code in assembly language 
; Program to calculate sum of squares: 1² + 2² + ... + n² 
NUM:    DW 0x5          ; n = 5 → sum = 1²+2²+3²+4²+5² = 55 
RESULT: DW 0            ; stores final result 
 
start: 
    MOV CX, word NUM    ; CX = n (loop counter) 
    MOV AX, 0x0         ; AX = 0 (running sum) 
 
SQUARELOOP: 
    PUSH AX             ; save running sum 
    MOV AX, CX          ; AX = current counter value 
    MUL CX              ; AX = CX * CX  (i.e. CX²) 
    MOV BX, AX          ; BX = CX² (temporary) 
    POP AX              ; restore running sum 
    ADD AX, BX          ; AX = sum + CX² 
    DEC CX              ; CX = CX - 1 
    JNZ SQUARELOOP      ; if CX != 0, repeat 
 
    MOV word RESULT, AX ; RESULT = 1²+2²+...+n²     print reg

