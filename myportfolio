<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ARSHAD — AI Agent Developer & Full Stack UX Designer</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0a0a0a;
      --bg-panel: #111111;
      --bg-grid: #161616;
      --border: #222222;
      --text: #e0dcd4;
      --text-dim: #5a5450;
      --te-orange: #ff5e2b;
      --te-green: #2ecc71;
      --te-blue: #3498db;
      --te-white: #e8e4dc;
      --te-red: #e74c3c;
      --te-purple: #9b59b6;
      --glow-orange: 0 0 10px #ff5e2b44;
      --glow-green: 0 0 10px #2ecc7144;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'JetBrains Mono', monospace;
      background: var(--bg);
      color: var(--text);
      font-size: 13px;
      line-height: 1.6;
      letter-spacing: -0.2px;
      overflow-x: hidden;
    }

    a { color: var(--te-orange); text-decoration: none; }

    /* ─── CRT SCANLINES ─── */
    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0;
      width: 100vw; height: 100vh;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.03) 2px,
        rgba(0,0,0,0.03) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }

    /* ─── POWER-ON BOOT SEQUENCE ─── */
    #boot-overlay {
      position: fixed;
      inset: 0;
      background: var(--bg);
      z-index: 10000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      letter-spacing: 2px;
    }
    .boot-line {
      color: var(--te-orange);
      margin: 4px 0;
      opacity: 0;
      transform: translateY(10px);
    }
    .boot-line.visible {
      animation: bootIn 0.4s ease forwards;
    }
    @keyframes bootIn {
      to { opacity: 1; transform: translateY(0); }
    }
    .boot-cursor {
      display: inline-block;
      width: 8px; height: 14px;
      background: var(--te-orange);
      margin-left: 4px;
      animation: blink .5s infinite;
    }
    #boot-bar {
      width: 200px;
      height: 2px;
      background: var(--border);
      margin-top: 24px;
      position: relative;
      overflow: hidden;
    }
    #boot-fill {
      position: absolute;
      left: 0; top: 0;
      height: 100%;
      width: 0%;
      background: var(--te-orange);
      box-shadow: 0 0 8px var(--te-orange);
      transition: width 0.2s linear;
    }

    /* ─── GLITCH ─── */
    .glitch {
      position: relative;
    }
    .glitch::before,
    .glitch::after {
      content: attr(data-text);
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      opacity: 0;
    }
    .glitch:hover::before {
      animation: glitch-1 0.3s cubic-bezier(.25,.46,.45,.94) both infinite;
      color: var(--te-blue);
      z-index: -1;
      opacity: 0.8;
    }
    .glitch:hover::after {
      animation: glitch-2 0.3s cubic-bezier(.25,.46,.45,.94) reverse both infinite;
      color: var(--te-red);
      z-index: -2;
      opacity: 0.8;
    }
    @keyframes glitch-1 {
      0% { clip-path: inset(20% 0 60% 0); transform: translate(-2px,0); }
      20% { clip-path: inset(60% 0 10% 0); transform: translate(2px,0); }
      40% { clip-path: inset(40% 0 40% 0); transform: translate(-2px,0); }
      60% { clip-path: inset(80% 0 5% 0); transform: translate(2px,0); }
      80% { clip-path: inset(10% 0 70% 0); transform: translate(-1px,0); }
      100% { clip-path: inset(50% 0 30% 0); transform: translate(1px,0); }
    }
    @keyframes glitch-2 {
      0% { clip-path: inset(10% 0 70% 0); transform: translate(2px,0); }
      20% { clip-path: inset(70% 0 10% 0); transform: translate(-2px,0); }
      40% { clip-path: inset(30% 0 50% 0); transform: translate(2px,0); }
      60% { clip-path: inset(50% 0 40% 0); transform: translate(-2px,0); }
      80% { clip-path: inset(15% 0 65% 0); transform: translate(1px,0); }
      100% { clip-path: inset(65% 0 15% 0); transform: translate(-1px,0); }
    }

    /* ─── FLICKER ─── */
    .flicker { animation: flicker 4s infinite; }
    @keyframes flicker {
      0%, 100% { opacity: 1; }
      41% { opacity: 1; }
      42% { opacity: 0.4; }
      43% { opacity: 1; }
      45% { opacity: 1; }
      46% { opacity: 0.2; }
      47% { opacity: 1; }
      92% { opacity: 1; }
      93% { opacity: 0.6; }
      94% { opacity: 1; }
    }

    /* ─── TOP BAR ─── */
    .top-bar {
      background: var(--bg-panel);
      border-bottom: 1px solid var(--border);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 100;
      animation: slideDown 0.6s ease-out;
    }
    @keyframes slideDown {
      from { transform: translateY(-100%); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    .logo-block { display: flex; align-items: center; gap: 10px; }
    .logo-text {
      font-weight: 800;
      font-size: 15px;
      letter-spacing: 2px;
      color: var(--text);
    }
    .logo-text span { color: var(--te-orange); }
    .status-led {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--te-green);
      box-shadow: 0 0 6px var(--te-green);
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--te-green); }
      50% { opacity: 0.4; box-shadow: 0 0 2px var(--te-green); }
    }
    .nav { display: flex; gap: 4px; margin-left: auto; }
    .nav a {
      color: var(--text-dim);
      font-size: 11px;
      padding: 6px 14px;
      border: 1px solid transparent;
      letter-spacing: 1px;
      text-transform: uppercase;
      transition: all .15s;
    }
    .nav a:hover, .nav a.active {
      color: var(--te-orange);
      border-color: var(--border);
      background: var(--bg-grid);
      text-decoration: none;
      box-shadow: var(--glow-orange);
    }

    /* ─── PAGE ─── */
    .page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 32px 24px;
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 24px;
      opacity: 0;
      animation: fadeUp 0.8s 2.2s ease forwards;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (max-width: 768px) { .page { grid-template-columns: 1fr; } }

    /* ─── PANELS ─── */
    .panel {
      background: var(--bg-panel);
      border: 1px solid var(--border);
      position: relative;
      transition: box-shadow 0.3s;
    }
    .panel:hover { box-shadow: 0 0 20px rgba(255,94,43,0.06); }
    .panel::before, .panel::after {
      content: '';
      position: absolute;
      width: 6px; height: 6px;
      border: 1px solid var(--border);
    }
    .panel::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
    .panel::after { top: -1px; right: -1px; border-left: none; border-bottom: none; }
    .panel-inner::before, .panel-inner::after {
      content: '';
      position: absolute;
      width: 6px; height: 6px;
      border: 1px solid var(--border);
    }
    .panel-inner::before { bottom: -1px; left: -1px; border-right: none; border-top: none; }
    .panel-inner::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }

    .screw {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: linear-gradient(135deg, #333 0%, #111 100%);
      border: 1px solid #3a3a3a;
      position: relative;
      display: inline-block;
    }
    .screw::after {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      width: 6px; height: 1px;
      background: #555;
      transform: translate(-50%, -50%) rotate(45deg);
    }

    .module-header {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      background: var(--bg-grid);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--text-dim);
    }
    .module-body { padding: 16px; }

    /* ─── AVATAR ─── */
    .avatar-box {
      width: 200px; height: 200px;
      background: var(--bg-grid);
      border: 1px solid var(--border);
      margin: 0 auto 16px;
      position: relative;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      transition: transform 0.3s;
    }
    .avatar-box:hover { transform: scale(1.02); }
    .avatar-box img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: grayscale(30%) contrast(1.1);
      transition: filter 0.4s;
    }
    .avatar-box:hover img { filter: grayscale(0%) contrast(1.2); }
    .avatar-fallback {
      font-size: 64px;
      font-weight: 800;
      color: var(--te-orange);
    }
    .corner {
      position: absolute;
      width: 8px; height: 8px;
      border: 1px solid var(--te-orange);
    }
    .corner-tl { top: -1px; left: -1px; border-right: none; border-bottom: none; }
    .corner-tr { top: -1px; right: -1px; border-left: none; border-bottom: none; }
    .corner-bl { bottom: -1px; left: -1px; border-right: none; border-top: none; }
    .corner-br { bottom: -1px; right: -1px; border-left: none; border-top: none; }

    .id-block { text-align: center; margin-bottom: 16px; opacity: 0; animation: reveal 0.5s 2.6s ease forwards; }
    .id-name { font-size: 16px; font-weight: 700; letter-spacing: 1px; }
    .id-handle { font-size: 11px; color: var(--text-dim); margin-top: 2px; }

    .param-row {
      display: flex;
      justify-content: space-between;
      padding: 6px 0;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
      opacity: 0;
      transform: translateX(-10px);
      animation: slideIn 0.3s ease forwards;
    }
    .param-row:nth-child(1) { animation-delay: 2.7s; }
    .param-row:nth-child(2) { animation-delay: 2.8s; }
    .param-row:nth-child(3) { animation-delay: 2.9s; }
    .param-row:nth-child(4) { animation-delay: 3.0s; }
    .param-row:nth-child(5) { animation-delay: 3.1s; }
    .param-row:nth-child(6) { animation-delay: 3.2s; }
    @keyframes slideIn {
      to { opacity: 1; transform: translateX(0); }
    }
    .param-label { color: var(--text-dim); text-transform: uppercase; letter-spacing: .5px; }
    .param-val { color: var(--te-orange); }

    /* ─── ENCODERS ─── */
    .encoder-strip { display: flex; gap: 8px; margin-top: 14px; }
    .encoder { flex: 1; text-align: center; }
    .encoder-knob {
      width: 32px; height: 32px;
      border-radius: 50%;
      border: 2px solid;
      margin: 0 auto 6px;
      position: relative;
      transition: transform 0.4s cubic-bezier(.25,.46,.45,.94);
    }
    .encoder:hover .encoder-knob {
      transform: rotate(180deg);
    }
    .encoder-knob::after {
      content: '';
      position: absolute;
      top: 3px; left: 50%;
      width: 2px; height: 10px;
      transform: translateX(-50%);
    }
    .enc-green .encoder-knob { border-color: var(--te-green); }
    .enc-green .encoder-knob::after { background: var(--te-green); }
    .enc-blue .encoder-knob { border-color: var(--te-blue); }
    .enc-blue .encoder-knob::after { background: var(--te-blue); }
    .enc-orange .encoder-knob { border-color: var(--te-orange); }
    .enc-orange .encoder-knob::after { background: var(--te-orange); }
    .enc-white .encoder-knob { border-color: var(--te-white); }
    .enc-white .encoder-knob::after { background: var(--te-white); }
    .encoder-label { font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }

    .pill-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 10px;
    }
    .hw-pill {
      font-size: 10px;
      padding: 3px 8px;
      border: 1px solid var(--border);
      background: var(--bg-grid);
      color: var(--text-dim);
      letter-spacing: .5px;
      transition: all 0.2s;
      cursor: default;
    }
    .hw-pill:hover {
      border-color: var(--te-orange);
      color: var(--te-orange);
      box-shadow: var(--glow-orange);
    }

    /* ─── MAIN ─── */
    .main { display: flex; flex-direction: column; gap: 20px; }

    .screen {
      background: var(--bg-panel);
      border: 1px solid var(--border);
      position: relative;
      padding: 20px;
      opacity: 0;
      transform: translateY(12px);
      animation: reveal 0.5s 2.4s ease forwards;
    }
    @keyframes reveal {
      to { opacity: 1; transform: translateY(0); }
    }
    .screen-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }
    .screen-title {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--text-dim);
    }
    .screen-title span { color: var(--te-orange); }

    .tab-rail {
      display: flex;
      gap: 2px;
      margin-bottom: 20px;
      opacity: 0;
      animation: reveal 0.4s 2.5s ease forwards;
    }
    .tab-rail button {
      background: var(--bg-grid);
      border: 1px solid var(--border);
      color: var(--text-dim);
      font-family: inherit;
      font-size: 10px;
      padding: 8px 16px;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
    }
    .tab-rail button::after {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,94,43,0.1), transparent);
      transition: left 0.3s;
    }
    .tab-rail button:hover::after { left: 100%; }
    .tab-rail button:hover { color: var(--text); border-color: var(--te-orange); }
    .tab-rail button.active {
      background: var(--te-orange);
      border-color: var(--te-orange);
      color: var(--bg);
      font-weight: 600;
      box-shadow: 0 0 12px rgba(255,94,43,0.3);
    }

    .view {
      display: none;
      opacity: 0;
      transform: translateX(-8px);
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .view.active {
      display: block;
      opacity: 1;
      transform: translateX(0);
    }

    /* ─── DECODE TEXT ─── */
    .decode-text {
      opacity: 0;
      animation: decodeFade 0.3s ease forwards;
    }

    /* ─── TYPING ─── */
    .pixel-text {
      font-size: 22px;
      font-weight: 800;
      line-height: 1.3;
      margin-bottom: 12px;
      letter-spacing: -1px;
    }
    .cursor {
      display: inline-block;
      width: 10px; height: 18px;
      background: var(--te-orange);
      animation: blink .8s infinite;
      vertical-align: middle;
      margin-left: 4px;
      box-shadow: 0 0 6px var(--te-orange);
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    .readout {
      color: var(--text-dim);
      font-size: 12px;
      line-height: 1.8;
      margin-bottom: 16px;
    }
    .readout strong { color: var(--te-white); font-weight: 500; }

    .list-term {
      padding: 6px 0;
      border-bottom: 1px solid var(--border);
      color: var(--text-dim);
      font-size: 12px;
      display: flex;
      gap: 10px;
      align-items: baseline;
      opacity: 0;
      transform: translateX(-8px);
      transition: all 0.2s;
    }
    .list-term.visible {
      animation: slideIn 0.3s ease forwards;
    }
    .list-term:hover {
      color: var(--text);
      padding-left: 4px;
      border-left: 2px solid var(--te-orange);
    }
    .list-term:last-child { border-bottom: none; }
    .list-bullet { color: var(--te-orange); font-weight: 700; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 600px) { .grid-2 { grid-template-columns: 1fr; } }

    /* ─── DEVICE CARDS ─── */
    .device {
      background: var(--bg-grid);
      border: 1px solid var(--border);
      padding: 14px;
      position: relative;
      transition: all 0.3s cubic-bezier(.25,.46,.45,.94);
      transform-style: preserve-3d;
      perspective: 600px;
      opacity: 0;
      transform: translateY(10px) rotateX(4deg);
    }
    .device.visible {
      animation: deviceIn 0.4s ease forwards;
    }
    @keyframes deviceIn {
      to { opacity: 1; transform: translateY(0) rotateX(0); }
    }
    .device:hover {
      border-color: var(--te-orange);
      transform: translateY(-3px) rotateX(0);
      box-shadow: var(--glow-orange);
    }
    .device::before {
      content: '';
      position: absolute;
      top: 8px; right: 8px;
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--te-green);
      box-shadow: 0 0 4px var(--te-green);
      animation: pulse 2s infinite;
    }
    .device-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 8px;
    }
    .device-id {
      font-size: 12px;
      font-weight: 700;
      color: var(--te-orange);
      letter-spacing: .5px;
      transition: color 0.2s;
    }
    .device:hover .device-id { color: var(--te-white); }
    .device-type {
      font-size: 9px;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .device-desc {
      font-size: 11px;
      color: var(--text-dim);
      line-height: 1.6;
      margin-bottom: 10px;
    }
    .device-tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .device-tags span {
      font-size: 9px;
      padding: 2px 6px;
      border: 1px solid var(--border);
      color: var(--text-dim);
      transition: all 0.2s;
    }
    .device:hover .device-tags span {
      border-color: var(--te-orange);
      color: var(--te-orange);
    }

    /* ─── TRACKS ─── */
    .track { display: flex; flex-direction: column; gap: 0; }
    .track-row {
      display: flex;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid var(--border);
      opacity: 0;
      transform: translateX(-12px);
      transition: all 0.2s;
    }
    .track-row.visible { animation: slideIn 0.4s ease forwards; }
    .track-row:hover { background: rgba(255,94,43,0.03); padding-left: 8px; }
    .track-row:last-child { border-bottom: none; }
    .track-channel {
      width: 32px; min-width: 32px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }
    .track-num {
      font-size: 9px;
      color: var(--text-dim);
      text-transform: uppercase;
    }
    .track-led {
      width: 8px; height: 8px;
      border-radius: 2px;
      background: var(--border);
      transition: all 0.3s;
    }
    .track-led.on { background: var(--te-green); box-shadow: 0 0 4px var(--te-green); }
    .track-led.blue { background: var(--te-blue); box-shadow: 0 0 4px var(--te-blue); }
    .track-led.orange { background: var(--te-orange); box-shadow: 0 0 4px var(--te-orange); }
    .track-led.pulse { animation: pulse 1.5s infinite; }
    .track-info { flex: 1; }
    .track-title { font-size: 13px; font-weight: 600; color: var(--text); letter-spacing: .3px; }
    .track-meta { font-size: 10px; color: var(--te-orange); margin: 2px 0 6px; letter-spacing: .5px; }
    .track-body { font-size: 11px; color: var(--text-dim); line-height: 1.6; }

    /* ─── FIGMA UNITS ─── */
    .figma-unit {
      background: var(--bg-grid);
      border: 1px solid var(--border);
      overflow: hidden;
      transition: all 0.3s;
      opacity: 0;
      transform: scale(0.96);
    }
    .figma-unit.visible { animation: scaleIn 0.4s ease forwards; }
    @keyframes scaleIn {
      to { opacity: 1; transform: scale(1); }
    }
    .figma-unit:hover {
      border-color: var(--te-purple);
      box-shadow: 0 0 16px rgba(155,89,182,0.15);
      transform: translateY(-2px);
    }
    .figma-display {
      height: 140px;
      background: linear-gradient(135deg, #111 0%, #0a0a0a 100%);
      display: flex; align-items: center; justify-content: center;
      font-size: 40px;
      border-bottom: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }
    .figma-display::before {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.2) 2px, rgba(0,0,0,0.2) 4px);
    }
    .figma-display::after {
      content: '';
      position: absolute;
      bottom: 8px; right: 8px;
      width: 20px; height: 2px;
      background: var(--te-orange);
      animation: flicker 3s infinite;
    }
    .figma-body { padding: 12px; }
    .figma-name { font-size: 12px; font-weight: 600; margin-bottom: 4px; letter-spacing: .3px; }
    .figma-detail { font-size: 10px; color: var(--text-dim); line-height: 1.5; }
    .figma-tag {
      display: inline-block;
      margin-top: 8px;
      font-size: 9px;
      color: var(--te-purple);
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    /* ─── PATCH BAY ─── */
    .patch-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px;
    }
    .patch {
      background: var(--bg-grid);
      border: 1px solid var(--border);
      padding: 14px;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: all 0.25s;
      opacity: 0;
      transform: translateY(8px);
    }
    .patch.visible { animation: reveal 0.3s ease forwards; }
    .patch:hover {
      border-color: var(--te-orange);
      background: rgba(255,94,43,0.04);
      transform: translateY(-2px);
      box-shadow: var(--glow-orange);
      text-decoration: none;
    }
    .patch-jack {
      width: 14px; height: 14px;
      border-radius: 50%;
      border: 2px solid var(--border);
      background: var(--bg);
      position: relative;
      transition: all 0.3s;
    }
    .patch:hover .patch-jack {
      transform: scale(1.2);
      box-shadow: 0 0 8px currentColor;
    }
    .patch-jack::after {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      width: 4px; height: 4px;
      border-radius: 50%;
      transform: translate(-50%, -50%);
    }
    .patch-jack.orange { border-color: var(--te-orange); }
    .patch-jack.orange::after { background: var(--te-orange); }
    .patch-jack.blue { border-color: var(--te-blue); }
    .patch-jack.blue::after { background: var(--te-blue); }
    .patch-jack.green { border-color: var(--te-green); }
    .patch-jack.green::after { background: var(--te-green); }
    .patch-jack.white { border-color: var(--te-white); }
    .patch-jack.white::after { background: var(--te-white); }
    .patch-info { flex: 1; }
    .patch-label { font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }
    .patch-val { font-size: 12px; color: var(--text); font-weight: 500; }

    /* ─── CONTRIBUTION GRID ─── */
    .contrib-grid { display: flex; gap: 3px; overflow-x: auto; padding: 4px; }
    .contrib-day {
      width: 10px; height: 10px;
      border-radius: 1px;
      cursor: pointer;
      transition: all 0.15s;
      position: relative;
    }
    .contrib-day:hover {
      transform: scale(1.6);
      z-index: 2;
      box-shadow: 0 0 6px rgba(255,255,255,0.2);
    }

    /* ─── FOOTER ─── */
    .foot {
      text-align: center;
      padding: 24px;
      border-top: 1px solid var(--border);
      color: var(--text-dim);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-top: 20px;
      opacity: 0;
      animation: reveal 0.5s 3s ease forwards;
    }
    .foot span { color: var(--te-orange); }

    /* ─── RIPPLE ON CLICK ─── */
    .ripple {
      position: absolute;
      border-radius: 50%;
      background: rgba(255,94,43,0.2);
      transform: scale(0);
      animation: ripple 0.6s linear;
      pointer-events: none;
    }
    @keyframes ripple {
      to { transform: scale(4); opacity: 0; }
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 1px; }

    /* ─── TERMINAL COMMAND INPUT ─── */
    .terminal-panel {
      border-top: 1px solid var(--border);
      background: var(--bg-panel);
      padding: 12px 24px;
      margin-top: 32px;
