<script>
  // ─── BOOT SEQUENCE ───
  const bootLines = [
    'INITIALIZING HARDWARE...',
    'LOADING KERNEL modules/arshad.bin',
    'MOUNTING /dev/portfolio',
    'CALIBRATING ENCODERS... OK',
    'SCANNING REPOSITORIES... 26 FOUND',
    'LINKING FIGMA WORKSPACE... OK',
    'ESTABLISHING CONNECTION...',
    'SYSTEM READY.'
  ];
  const bootContent = document.getElementById('boot-content');
  const bootFill = document.getElementById('boot-fill');
  const bootOverlay = document.getElementById('boot-overlay');

  async function runBoot() {
    for (let i = 0; i < bootLines.length; i++) {
      const div = document.createElement('div');
      div.className = 'boot-line';
      div.innerHTML = `[${String(i+1).padStart(2,'0')}/${String(bootLines.length).padStart(2,'0')}] ${bootLines[i]}<span class="boot-cursor"></span>`;
      bootContent.appendChild(div);
      await new Promise(r => setTimeout(r, 80));
      div.classList.add('visible');
      bootFill.style.width = `${((i+1)/bootLines.length)*100}%`;
      await new Promise(r => setTimeout(r, 180));
    }
    await new Promise(r => setTimeout(r, 400));
    bootOverlay.style.transition = 'opacity 0.6s';
    bootOverlay.style.opacity = '0';
    await new Promise(r => setTimeout(r, 600));
    bootOverlay.style.display = 'none';
    startRevealAnimations();
  }

  function startRevealAnimations() {
    // Staggered reveals for lists and cards
    const lists = document.querySelectorAll('.list-term');
    lists.forEach((el, i) => { el.style.animationDelay = `${2.8 + i*0.1}s`; el.classList.add('visible'); });

    const devices = document.querySelectorAll('.device');
    devices.forEach((el, i) => { el.style.animationDelay = `${3.0 + i*0.08}s`; el.classList.add('visible'); });

    const figmaUnits = document.querySelectorAll('.figma-unit');
    figmaUnits.forEach((el, i) => { el.style.animationDelay = `${2.9 + i*0.1}s`; el.classList.add('visible'); });

    const patches = document.querySelectorAll('.patch');
    patches.forEach((el, i) => { el.style.animationDelay = `${2.8 + i*0.1}s`; el.classList.add('visible'); });

    const trackRows = document.querySelectorAll('.track-row');
    trackRows.forEach((el, i) => { el.style.animationDelay = `${2.7 + i*0.12}s`; el.classList.add('visible'); });
  }

  // ─── VIEW SWITCHING ───
  function showView(view, btn) {
    document.querySelectorAll('.view').forEach(v => {
      v.classList.remove('active');
      v.style.opacity = '0';
      v.style.transform = 'translateX(-8px)';
    });
    document.querySelectorAll('.tab-rail button').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.nav a').forEach(a => a.classList.remove('active'));

    const target = document.getElementById('view-' + view);
    target.classList.add('active');
    requestAnimationFrame(() => {
      target.style.opacity = '1';
      target.style.transform = 'translateX(0)';
    });

    if(btn) btn.classList.add('active');
    const map = {'overview':'overview','repos':'repos','design':'design','exp':'exp','contact':'contact'};
    const navLink = document.querySelector(`.nav a[href="#${map[view] || view}"]`);
    if(navLink) navLink.classList.add('active');
  }

  // ─── RIPPLE EFFECT ───
  document.addEventListener('click', function(e) {
    if (e.target.closest('.screen, .device, .patch, .figma-unit')) {
      const el = e.target.closest('.screen, .device, .patch, .figma-unit');
      const ripple = document.createElement('span');
      ripple.className = 'ripple';
      const rect = el.getBoundingClientRect();
      ripple.style.left = (e.clientX - rect.left) + 'px';
      ripple.style.top = (e.clientY - rect.top) + 'px';
      el.appendChild(ripple);
      setTimeout(() => ripple.remove(), 600);
    }
  });

  // ─── CONTRIBUTION GRID ───
  const grid = document.getElementById('contrib-grid');
  if(grid) {
    const colors = ['#161616','#0e4429','#006d32','#26a641','#39d353'];
    for(let w=0; w<52; w++){
      const week = document.createElement('div');
      week.style.cssText = 'display:flex; flex-direction:column; gap:3px;';
      for(let d=0; d<7; d++){
        const day = document.createElement('div');
        day.className = 'contrib-day';
        const l = Math.floor(Math.random()*5);
        day.style.background = colors[l];
        day.title = `${l*3} events`;
        week.appendChild(day);
      }
      grid.appendChild(week);
    }
  }

  // ─── REPO LIST ───
  const repos = [
    {name:'sevasetu', desc:'MERN municipal complaint platform with role dashboards and analytics', tags:['JavaScript','MERN','MongoDB']},
    {name:'report-nest', desc:'Python/Flask student report card system with parent portals and PDF export', tags:['Python','Flask','SQL']},
    {name:'smart-escalation', desc:'React + Node/Express escalation system with JWT auth and SLA tracking', tags:['React','Node','JWT']},
    {name:'dsa-practice', desc:'DSA implementations in C++ and JS with complexity analysis', tags:['C++','Algorithms']},
    {name:'dbms-notes', desc:'Database queries, schemas, normalization examples and ER diagrams', tags:['SQL','DBMS']},
    {name:'portfolio-figma', desc:'Figma design files for portfolio UI components and design system', tags:['Figma','UI']},
  ];
  const repoList = document.getElementById('repo-list');
  repos.forEach((r,i) => {
    repoList.innerHTML += `
      <div class="device" style="animation-delay:${3.0+i*0.08}s">
        <div class="device-header"><div><div class="device-type">Public</div><div class="device-id">${r.name}</div></div></div>
        <div class="device-desc">${r.desc}</div>
        <div class="device-tags">${r.tags.map(t=>`<span>${t}</span>`).join('')}</div>
      </div>`;
  });

  // ─── TERMINAL COMMAND HANDLER ───
  const terminal = document.getElementById('terminal-output');
  const cmdInput = document.getElementById('cmd-input');
  
  if (terminal && cmdInput) {
    const commands = {
      overview: () => { showView('overview'); return 'Navigated to Overview'; },
      repos: () => { showView('repos'); return 'Navigated to Repositories'; },
      design: () => { showView('design'); return 'Navigated to Figma'; },
      exp: () => { showView('exp'); return 'Navigated to Experience'; },
      contact: () => { showView('contact'); return 'Navigated to I/O'; },
      help: () => {
        return `Available Commands:\n  goto <section>   Navigate to section (overview, repos, design, exp, contact)\n  overview         Jump to overview\n  repos            Jump to repositories\n  design           Jump to Figma workspace\n  exp              Jump to experience\n  contact          Jump to I/O\n  time             Show current time\n  clear            Clear terminal\n  help             Show this help`;
      },
      time: () => {
        const now = new Date();
        return `Current time: ${now.toLocaleTimeString()}`;
      },
      clear: () => { terminal.innerHTML = ''; return null; }
    };

    function executeCommand(input) {
      const parts = input.toLowerCase().trim().split(' ');
      const cmd = parts[0];
      const arg = parts[1];
      let output = '';

      if (cmd === 'goto' && arg) {
        const section = arg.toLowerCase();
        if (commands[section]) {
          output = commands[section]();
        } else {
          output = `Unknown section: ${arg}`;
        }
      } else if (commands[cmd]) {
        output = commands[cmd]();
      } else {
        output = `Command not found: ${cmd}. Type 'help' for available commands.`;
      }

      if (output !== null) {
        const line = `${output}`;
        terminal.innerHTML += (terminal.innerHTML ? '\n' : '') + line;
        terminal.scrollTop = terminal.scrollHeight;
      }
    }

    cmdInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        const cmd = cmdInput.value;
        if (cmd.trim()) {
          terminal.innerHTML += (terminal.innerHTML ? '\n' : '') + `root@arshad ~$ ${cmd}`;
          executeCommand(cmd);
          cmdInput.value = '';
          terminal.scrollTop = terminal.scrollHeight;
        }
      }
    });
  }

  // Start boot on load
  runBoot();
</script>
</body>
</html>
